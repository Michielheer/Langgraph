---
const stappen = [
  {
    nr: "01",
    titel: "Portefeuille erin",
    tekst:
      "Export uit ANVA/Level, CCS of Progress OpenEdge. CSV, ODBC of Access: het formaat dat je toch al hebt voor de conversie.",
  },
  {
    nr: "02",
    titel: "Scan tijdens de conversie",
    tekst:
      "Elke polis wordt gecheckt tegen een normprofiel per productlijn. De scan draait mee in de conversierun zelf: nul vertraging.",
  },
  {
    nr: "03",
    titel: "Leads eruit",
    tekst:
      "Per klant: welk gat, welk product, welke geschatte jaarpremie. Direct klaar voor de migratiebrief of het CRM.",
  },
];
---

<section id="werkwijze" class="mx-auto max-w-[1200px] px-6 py-20 md:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="font-display text-[13px] font-medium uppercase tracking-[0.16em] text-periwinkle-deep">Werkwijze</p>
    <h2 class="font-display mt-4 text-[clamp(2rem,3.6vw,3rem)] font-light leading-[1.08] tracking-[-0.03em] text-indigo-ink">
      Drie stappen, in de volgorde waarin het echt gebeurt.
    </h2>
  </div>

  <div class="mt-14 grid gap-6 md:grid-cols-3">
    {
      stappen.map((stap) => (
        <div class="reveal tilt rounded-2xl border border-mist bg-paper p-8 hover:border-lilac hover:shadow-float">
          <p class="font-display text-3xl font-light text-periwinkle">{stap.nr}</p>
          <h3 class="font-display mt-5 text-2xl font-medium tracking-tight text-indigo-ink">{stap.titel}</h3>
          <p class="mt-3 leading-relaxed text-storm">{stap.tekst}</p>
        </div>
      ))
    }
  </div>
</section>
