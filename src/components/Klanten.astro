---
// Klanten / social proof. Echte logo's in nette witte tegels.
const klanten = [
  { naam: "NH1816 Verzekeringen", src: "/logos/nh1816.png", w: 1280, h: 582 },
  { naam: "Mevas", src: "/logos/mevas.jpg", w: 460, h: 300 },
  { naam: "Univé", src: "/logos/unive.webp", w: 400, h: 169 },
];
---

<section id="klanten" class="mx-auto max-w-[1200px] px-6 pb-12 pt-2 md:pb-16">
  <p class="reveal text-center font-display text-[13px] font-medium uppercase tracking-[0.16em] text-fog">
    Vertrouwd door
  </p>
  <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-4 sm:gap-6">
    {
      klanten.map((k) => (
        <div class="flex h-20 min-w-[168px] items-center justify-center rounded-2xl border border-mist bg-paper px-8">
          <img
            src={k.src}
            alt={`Logo ${k.naam}`}
            width={k.w}
            height={k.h}
            loading="lazy"
            class="max-h-11 w-auto"
          />
        </div>
      ))
    }
  </div>
</section>
