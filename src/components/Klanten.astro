---
// Klanten / social proof. Monochrome wordmerken (RevenueCat "logo cloud"-patroon).
// Echte klanten, geen placeholder. Officiële logo's kunnen later de tekst vervangen.
const klanten = ["NH1816 Verzekeringen", "Univé"];
---

<section id="klanten" class="mx-auto max-w-[1200px] px-6 pb-10 pt-2 md:pb-16">
  <p class="reveal text-center font-display text-[13px] font-medium uppercase tracking-[0.16em] text-fog">
    Vertrouwd door
  </p>
  <div class="reveal mt-6 flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
    {
      klanten.map((naam) => (
        <span class="font-display text-2xl font-semibold tracking-tight text-slate sm:text-[28px]">
          {naam}
        </span>
      ))
    }
  </div>
</section>
