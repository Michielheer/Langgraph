---
// Iconen: Lucide (ISC-licentie), inline SVG paths
const types = [
  {
    titel: "Ontbrekende rechtsbijstand",
    tekst: "Woonpolis aanwezig, rechtsbijstand niet. Het meest voorkomende — en makkelijkst te dichten — gat.",
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M10 12l4 4m0-4l-4 4",
  },
  {
    titel: "Onderverzekering",
    tekst: "Verzekerde som die jaren niet is geïndexeerd terwijl herbouwwaarde en inboedel wél stegen.",
    icon: "M3 3v18h18M7 14l4-4 4 4 5-6",
  },
  {
    titel: "Losse opstal zonder inboedel",
    tekst: "Opstal gedekt, inboedel nergens te vinden — of andersom. Halve dekking op het grootste bezit.",
    icon: "M3 10.5 12 3l9 7.5M5 9.5V21h14V9.5M9 21v-6h6v6",
  },
  {
    titel: "Geen aansprakelijkheid (AVP)",
    tekst: "Gezinnen zonder AVP terwijl de rest van het pakket volledig is. Klein bedrag, groot risico.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  },
  {
    titel: "Dubbele dekking",
    tekst: "Twee polissen die hetzelfde risico dekken. Opzeggen is ook advieswaarde — en vertrouwen.",
    icon: "M8 8h12v12H8zM4 16V4h12",
  },
  {
    titel: "Verouderd risico",
    tekst: "Polissen die niet meer passen bij de huidige situatie: verbouwd, verhuisd, gestopt met ondernemen.",
    icon: "M12 8v4l3 3M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9z",
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-24">
  <div class="reveal">
    <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-amber">Wat we vinden</p>
    <h2 class="font-display mt-3 max-w-2xl text-3xl font-800 tracking-tight text-paper sm:text-4xl">
      Zes lek-types die in vrijwel elke portefeuille zitten.
    </h2>
  </div>

  <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      types.map((type) => (
        <div class="reveal rounded-2xl border border-line bg-surface p-6 transition-colors duration-200 hover:border-amber/30">
          <span class="flex h-11 w-11 items-center justify-center rounded-lg border border-amber/30 bg-amber/10">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-amber"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={type.icon} />
            </svg>
          </span>
          <h3 class="font-display mt-4 text-lg font-700 text-paper">{type.titel}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{type.tekst}</p>
        </div>
      ))
    }
  </div>
</section>
