---
// Iconen: Lucide (ISC-licentie), inline SVG paths.
// Badges: pastel wash (coral / mint / periwinkle / lavender) met icoon in donkere tint.
// Elk lek-type is gelabeld als cross-sell, upsell of optimalisatie.
const kindStyles: Record<string, string> = {
  "Cross-sell": "bg-periwinkle-mist text-indigo-ink",
  Upsell: "bg-mint-veil text-indigo-ink",
  Optimalisatie: "bg-bone text-indigo-ink",
};
const badges = [
  { bg: "bg-coral-blush", fg: "text-coral" },
  { bg: "bg-mint-veil", fg: "text-mint-deep" },
  { bg: "bg-periwinkle-mist", fg: "text-periwinkle-deep" },
  { bg: "bg-lilac", fg: "text-periwinkle-deep" },
  { bg: "bg-coral-blush", fg: "text-coral" },
  { bg: "bg-mint-veil", fg: "text-mint-deep" },
];
const types = [
  {
    titel: "Ontbrekende rechtsbijstand",
    kind: "Cross-sell",
    tekst: "Woonpolis aanwezig, rechtsbijstand niet. Het meest voorkomende gat, en het makkelijkst te dichten.",
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M10 12l4 4m0-4l-4 4",
  },
  {
    titel: "Onderverzekering",
    kind: "Upsell",
    tekst: "Verzekerde som die jaren niet is geïndexeerd terwijl herbouwwaarde en inboedel wél stegen.",
    icon: "M3 3v18h18M7 14l4-4 4 4 5-6",
  },
  {
    titel: "Losse opstal zonder inboedel",
    kind: "Cross-sell",
    tekst: "Opstal gedekt, inboedel nergens te vinden, of andersom. Halve dekking op het grootste bezit.",
    icon: "M3 10.5 12 3l9 7.5M5 9.5V21h14V9.5M9 21v-6h6v6",
  },
  {
    titel: "Geen aansprakelijkheid (AVP)",
    kind: "Cross-sell",
    tekst: "Gezinnen zonder AVP terwijl de rest van het pakket volledig is. Klein bedrag, groot risico.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  },
  {
    titel: "Dubbele dekking",
    kind: "Optimalisatie",
    tekst: "Twee polissen die hetzelfde risico dekken. Opzeggen is advieswaarde, en vertrouwen voor de rest.",
    icon: "M8 8h12v12H8zM4 16V4h12",
  },
  {
    titel: "Verouderd risico",
    kind: "Upsell",
    tekst: "Polissen die niet meer passen bij de huidige situatie: verbouwd, verhuisd, gestopt met ondernemen.",
    icon: "M12 8v4l3 3M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9z",
  },
];
---

<section class="mx-auto max-w-[1200px] px-6 py-20 md:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="font-display text-[13px] font-medium uppercase tracking-[0.16em] text-periwinkle-deep">Wat we vinden</p>
    <h2 class="font-display mt-4 text-[clamp(2rem,3.6vw,3rem)] font-light leading-[1.08] tracking-[-0.03em] text-indigo-ink">
      Zes lek-types die in vrijwel elke portefeuille zitten.
    </h2>
    <p class="mt-5 text-lg leading-relaxed text-storm">
      Elk lek is een concrete cross- of upsell-kans in je bestaande portefeuille: een ontbrekend
      product erbij, of een te lage dekking ophogen.
    </p>
  </div>

  <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      types.map((type, i) => (
        <div class="reveal tilt rounded-2xl border border-mist bg-paper p-8 hover:border-lilac hover:shadow-float">
          <div class="flex items-center justify-between gap-3">
            <span class:list={["flex h-10 w-10 items-center justify-center rounded-full", badges[i].bg]}>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class:list={["h-5 w-5", badges[i].fg]}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={type.icon} />
              </svg>
            </span>
            <span class:list={["rounded-full px-3 py-1 font-display text-[11px] font-medium uppercase tracking-[0.1em]", kindStyles[type.kind]]}>
              {type.kind}
            </span>
          </div>
          <h3 class="font-display mt-5 text-xl font-medium tracking-tight text-indigo-ink">{type.titel}</h3>
          <p class="mt-2.5 leading-relaxed text-storm">{type.tekst}</p>
        </div>
      ))
    }
  </div>
</section>
