---
const cijfers = [
  { waarde: "359", label: "polissen in de portefeuille" },
  { waarde: "€ 79.117", label: "huidige jaarpremie" },
  { waarde: "89", label: "woonpolissen zonder rechtsbijstand" },
  { waarde: "104", label: "leads gevonden" },
];
---

<section id="cases" class="mx-auto max-w-[1200px] px-6 py-20 md:py-28">
  <div class="reveal mx-auto max-w-5xl rounded-[32px] border border-mist bg-paper p-8 shadow-float sm:p-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-center md:gap-16">
      <div>
        <p class="font-display text-[13px] font-medium uppercase tracking-[0.16em] text-periwinkle-deep">Bewijs</p>
        <blockquote class="font-display mt-5 text-[clamp(1.6rem,2.6vw,2.25rem)] font-light leading-[1.15] tracking-[-0.02em] text-indigo-ink">
          "Uit één echte portefeuille van 125 klanten haalden we 104 leads en zichtbare jaarpremie
          die er al die tijd in verstopt zat."
        </blockquote>
        <p class="mt-5 leading-relaxed text-fog">
          Puur uit de conversiedata, zonder één extern bestand.
        </p>
      </div>
      <div class="md:border-l md:border-mist md:pl-16">
        <p class="font-display text-[clamp(3rem,5vw,4rem)] font-light leading-none tracking-[-0.03em] text-periwinkle">
          € 24.600
        </p>
        <p class="mt-3 leading-relaxed text-fog">
          aan zichtbare extra jaarpremie, gevonden tijdens de conversie.
        </p>
      </div>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-x-10 gap-y-8 border-t border-mist pt-10 sm:grid-cols-4">
      {
        cijfers.map((c) => (
          <div>
            <p class="font-display text-2xl font-medium tracking-tight text-indigo-ink sm:text-[28px]">{c.waarde}</p>
            <p class="mt-2 text-sm leading-snug text-fog">{c.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
