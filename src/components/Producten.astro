---
// Iconen: Lucide (ISC-licentie), inline SVG paths
const producten = [
  {
    naam: "Leaklight",
    vlaggenschip: true,
    tekst:
      "Premielek-detectie tijdens polisconversie. Scant elke polis die wordt overgezet op dekkingsgaten en levert per klant leads met geschatte jaarpremie — zonder het conversieproces te vertragen.",
    icon: "M12 2a7 7 0 0 0-4 12.7V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.3A7 7 0 0 0 12 2zM9 21h6",
    badge: { bg: "bg-periwinkle-mist", fg: "text-periwinkle" },
  },
  {
    naam: "RisicoScout",
    vlaggenschip: false,
    tekst:
      "AI-gedreven pandrisico-inschatting voor verzekeraars. Beoordeelt objectrisico's op basis van beschikbare pand- en omgevingsdata.",
    icon: "M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14zM21 21l-5-5",
    badge: { bg: "bg-coral-blush", fg: "text-coral" },
  },
  {
    naam: "Dekkingsparser",
    vlaggenschip: false,
    tekst:
      "Polisblad- en voorwaardenverwerking uit documenten. Maakt van PDF's gestructureerde dekkingsdata die je kunt vergelijken en doorzoeken.",
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M8 13h8M8 17h5",
    badge: { bg: "bg-mint-veil", fg: "text-mint-deep" },
  },
  {
    naam: "Conversie & migratie",
    vlaggenschip: false,
    tekst:
      "De kernpraktijk waar alles op draait: portefeuilleconversies via SIVI AOS/AFD, Level/ANVA en Progress OpenEdge.",
    icon: "M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4",
    badge: { bg: "bg-lilac", fg: "text-periwinkle" },
  },
];
---

<section id="producten" class="mx-auto max-w-[1200px] px-6 py-20 md:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="font-display text-[13px] font-medium uppercase tracking-[0.16em] text-periwinkle-deep">Producten</p>
    <h2 class="font-display mt-4 text-[clamp(2rem,3.6vw,3rem)] font-light leading-[1.08] tracking-[-0.03em] text-indigo-ink">
      Software die in productie meedraait. Geen concepten.
    </h2>
  </div>

  <div class="mt-14 grid gap-6 md:grid-cols-2">
    {
      producten.map((p) => (
        <div
          class:list={[
            "reveal tilt rounded-2xl border bg-paper p-8",
            p.vlaggenschip
              ? "border-lilac shadow-float md:col-span-2"
              : "border-mist hover:border-lilac hover:shadow-float",
          ]}
        >
          <div class="flex items-start justify-between gap-4">
            <span class:list={["flex h-10 w-10 shrink-0 items-center justify-center rounded-full", p.badge.bg]}>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class:list={["h-5 w-5", p.badge.fg]}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={p.icon} />
              </svg>
            </span>
            {p.vlaggenschip && (
              <span class="rounded-full bg-periwinkle-deep px-3.5 py-1.5 font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white">
                Vlaggenschip
              </span>
            )}
          </div>
          <h3 class="font-display mt-5 text-2xl font-medium tracking-tight text-indigo-ink">{p.naam}</h3>
          <p class:list={["mt-2.5 leading-relaxed text-storm", p.vlaggenschip && "max-w-2xl"]}>{p.tekst}</p>
        </div>
      ))
    }
  </div>
</section>
