---
const stats = [
  { id: "stat-polissen", target: 359, label: "polissen gescand", prefix: "", format: "int" },
  { id: "stat-leads", target: 104, label: "leads gevonden", prefix: "", format: "int" },
  { id: "stat-premie", target: 24600, label: "extra jaarpremie", prefix: "€", format: "money" },
];
---

<section id="top" class="mx-auto max-w-[1200px] px-6 pb-20 pt-16 md:pb-28 md:pt-24">
  <div class="grid items-center gap-14 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)]">
    <div>
      <p class="font-display text-[13px] font-medium uppercase tracking-[0.16em] text-periwinkle-deep">
        Premielek-detectie tijdens polisconversie
      </p>
      <h1 class="font-display mt-5 text-[clamp(2.5rem,5.4vw,4.5rem)] font-light leading-[1.03] tracking-[-0.04em] text-indigo-ink">
        Elke polis die je overzet, scannen we op gemiste premie.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-storm">
        Een conversie is nu data schuiven van A naar B. Leaklight draait mee tijdens die conversie
        en levert per klant de dekkingsgaten die blijven liggen, zonder je proces te vertragen.
      </p>
      <div class="mt-9 flex flex-col items-start gap-5 sm:flex-row sm:items-center">
        <a href="#contact" class="btn-primary px-7 py-3.5 text-base">
          Plan een scan op je portefeuille
        </a>
        <a href="#werkwijze" class="btn-ghost text-base">
          Zo werkt het
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </a>
      </div>
      <p class="mt-12 border-t border-mist pt-6 text-sm text-fog">
        Gebouwd voor: volmachtbedrijven · gevolmachtigd agenten · verzekeraars
      </p>
    </div>

    <!-- Signature element: 3D live scan als zwevende kaart -->
    <div class="rounded-2xl border border-mist bg-paper p-5 shadow-hero sm:p-6">
      <div class="flex items-center justify-between gap-3">
        <p class="flex items-center gap-2 font-display text-[13px] font-medium uppercase tracking-[0.14em] text-slate">
          <span class="pulse-dot inline-block h-2 w-2 rounded-full bg-periwinkle" aria-hidden="true"></span>
          Leaklight · live scan
        </p>
        <button
          id="rescan"
          class="btn-ghost rounded-full px-3 py-1.5 text-[13px]"
          aria-label="Scan opnieuw uitvoeren"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 3-6.7L3 8" />
            <path d="M3 3v5h5" />
          </svg>
          opnieuw scannen
        </button>
      </div>

      <div
        id="scan-stage"
        class="relative mt-4 h-72 overflow-hidden rounded-xl bg-cloud sm:h-80"
        role="img"
        aria-label="3D-visualisatie van een portefeuillescan: een periwinkle scanbalk veegt over een veld van polissen; polissen met een dekkingsgat lichten coraalrood op en komen omhoog, gedekte polissen kleuren mint."
      >
        <canvas id="scan-canvas" class="h-full w-full"></canvas>
      </div>

      <div class="mt-5 grid grid-cols-3 gap-4 border-t border-mist pt-5">
        {
          stats.map((s) => (
            <div>
              <p class="font-display text-2xl font-medium tracking-tight text-indigo-ink" id={s.id} data-target={s.target} data-prefix={s.prefix} data-format={s.format}>
                {s.prefix}0
              </p>
              <p class="mt-1 text-[13px] leading-tight text-fog">{s.label}</p>
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-[13px] text-fog">
        Cijfers uit één echte, geanonimiseerde volmachtportefeuille (125 klanten).
      </p>
    </div>
  </div>
</section>

<script>
  const LABELS = ["OP", "IN", "AVP", "AUTO", "RB", "BR"];
  const COLS = 8;
  const ROWS = 6;

  const stage = document.getElementById("scan-stage")!;
  const canvas = document.getElementById("scan-canvas") as HTMLCanvasElement;
  const rescanBtn = document.getElementById("rescan")!;
  const counters = ["stat-polissen", "stat-leads", "stat-premie"].map(
    (id) => document.getElementById(id)!,
  );
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Vaste seed (mulberry32) zodat het patroon elke pageload gelijk is (~30% lek).
  let seed = 20260721;
  const rand = () => {
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };

  const formatValue = (el: HTMLElement, value: number) => {
    const prefix = el.dataset.prefix ?? "";
    const formatted =
      el.dataset.format === "money"
        ? Math.round(value).toLocaleString("nl-NL")
        : String(Math.round(value));
    el.textContent = prefix + formatted;
  };
  const setCounters = (t: number) =>
    counters.forEach((el) => formatValue(el, t * Number(el.dataset.target)));

  // Celdata: vast patroon (~30% lek), gedeeld door 3D-scène en fallback
  const cellSpecs = Array.from({ length: COLS * ROWS }, () => ({
    leak: rand() < 0.3,
    label: LABELS[Math.floor(rand() * LABELS.length)],
  }));

  // Koppel DOM-events aan een scène-API (worker of main thread)
  const wire = (api: {
    resize: (w: number, h: number) => void;
    setPointer: (x: number, y: number) => void;
    clearPointer: () => void;
    rescan: () => void;
  }) => {
    new ResizeObserver(() => api.resize(stage.clientWidth, stage.clientHeight)).observe(stage);
    stage.addEventListener("pointermove", (e) => {
      const r = stage.getBoundingClientRect();
      api.setPointer((e.clientX - r.left) / r.width - 0.5, (e.clientY - r.top) / r.height - 0.5);
    });
    stage.addEventListener("pointerleave", () => api.clearPointer());
    rescanBtn.addEventListener("click", () => api.rescan());
  };

  const sceneOpts = () => ({
    width: stage.clientWidth,
    height: stage.clientHeight,
    dpr: Math.min(window.devicePixelRatio, 2),
    cols: COLS,
    rows: ROWS,
    cellSpecs,
    reducedMotion,
  });

  // Voorkeursroute: scène in een Web Worker op een OffscreenCanvas, zodat
  // three.js de main thread nooit blokkeert.
  const initWorker = () => {
    const off = canvas.transferControlToOffscreen();
    const worker = new Worker(new URL("../scripts/scanWorker.ts", import.meta.url), {
      type: "module",
    });
    worker.postMessage({ type: "init", canvas: off, ...sceneOpts() }, [off]);
    worker.onmessage = (e) => {
      if (e.data.type === "counters") setCounters(e.data.t);
    };
    wire({
      resize: (width, height) => worker.postMessage({ type: "resize", width, height }),
      setPointer: (x, y) => worker.postMessage({ type: "pointer", x, y }),
      clearPointer: () => worker.postMessage({ type: "pointerleave" }),
      rescan: () => worker.postMessage({ type: "rescan" }),
    });
  };

  const initMainThread = async () => {
    const { initScanScene } = await import("../scripts/scanScene");
    wire(initScanScene({ canvas, ...sceneOpts(), setCounters }));
  };

  const init = async () => {
    if ("transferControlToOffscreen" in canvas) {
      initWorker();
    } else {
      await initMainThread();
    }
  };

  // Lazy: 3D pas laden zodra de hero in beeld is (scheelt initiële load)
  const start = () => {
    init().catch(() => {
      // WebGL niet beschikbaar: toon een statisch 2D-grid als fallback
      canvas.remove();
      const grid = document.createElement("div");
      grid.className = "grid h-full grid-cols-8 gap-1.5";
      for (const spec of cellSpecs) {
        const cellEl = document.createElement("div");
        cellEl.className = "flex items-center justify-center rounded-md font-display text-[10px] font-medium";
        cellEl.style.cssText = spec.leak
          ? "background:#f7d4d4;border:1px solid #f25a5a;color:#8f1f1f"
          : "background:#c1f6e0;border:1px solid #a6f2d2;color:#2f8f6b";
        cellEl.textContent = spec.label;
        grid.appendChild(cellEl);
      }
      stage.appendChild(grid);
      setCounters(1);
    });
  };

  // Pas starten in idle-tijd, zodat de 3D-init de first load niet blokkeert
  const startIdle = () => {
    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => start(), { timeout: 2500 });
    } else {
      setTimeout(start, 300);
    }
  };

  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        io.disconnect();
        startIdle();
      }
    });
    io.observe(stage);
  } else {
    startIdle();
  }
</script>
