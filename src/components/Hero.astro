---
const stats = [
  { id: "stat-polissen", target: 359, label: "polissen gescand", prefix: "", format: "int" },
  { id: "stat-leads", target: 104, label: "leads gevonden", prefix: "", format: "int" },
  { id: "stat-premie", target: 24600, label: "extra jaarpremie", prefix: "€", format: "money" },
];
---

<section id="top" class="mx-auto max-w-6xl px-4 pb-16 pt-28 sm:px-6 md:pb-24 md:pt-36">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div>
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-amber">
        Premielek-detectie tijdens polisconversie
      </p>
      <h1 class="font-display mt-4 text-4xl font-800 leading-[1.05] tracking-tight text-paper sm:text-5xl">
        Elke polis die je overzet, scannen we op gemiste premie.
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
        Een conversie is nu data schuiven van A naar B. Leaklight draait mee tijdens die conversie
        en levert per klant de dekkingsgaten die blijven liggen — zonder je proces te vertragen.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="#contact" class="btn-primary rounded-lg px-6 py-3 text-center text-base font-semibold">
          Plan een scan op je portefeuille
        </a>
        <a href="#werkwijze" class="btn-secondary rounded-lg px-6 py-3 text-center text-base font-medium">
          Zo werkt het
        </a>
      </div>
      <p class="mt-10 border-t border-line pt-5 font-mono text-xs text-muted">
        Gebouwd voor: volmachtbedrijven · gevolmachtigd agenten · verzekeraars
      </p>
    </div>

    <!-- Signature element: live scan -->
    <div class="rounded-2xl border border-line bg-surface p-5 shadow-[0_0_60px_rgba(255,176,32,0.06)] sm:p-6">
      <div class="flex items-center justify-between gap-3">
        <p class="font-mono text-xs font-medium uppercase tracking-widest text-muted">
          <span class="text-amber">▮</span> Leaklight · live scan
        </p>
        <button
          id="rescan"
          class="btn-secondary rounded-md px-3 py-1.5 font-mono text-xs font-medium"
          aria-label="Scan opnieuw uitvoeren"
        >
          ↻ opnieuw scannen
        </button>
      </div>

      <div
        id="scan-grid"
        class="relative mt-4 grid grid-cols-6 gap-1.5 overflow-hidden rounded-lg"
        role="img"
        aria-label="Gesimuleerde portefeuillescan: een scanlijn loopt over een grid van polissen; polissen met een dekkingsgat lichten amber op, gedekte polissen mint."
      >
        <div
          id="scan-line"
          class="pointer-events-none absolute inset-x-0 top-0 z-10 h-10 opacity-0"
          style="background: linear-gradient(to bottom, transparent, rgba(255,176,32,0.22), rgba(255,176,32,0.5)); border-bottom: 1px solid rgba(255,176,32,0.9); box-shadow: 0 4px 24px rgba(255,176,32,0.35);"
          aria-hidden="true"
        >
        </div>
        <!-- Cellen worden via JS gevuld -->
      </div>

      <div class="mt-5 grid grid-cols-3 gap-3 border-t border-line pt-4">
        {
          stats.map((s) => (
            <div>
              <p class="font-mono text-lg font-bold text-paper sm:text-xl" id={s.id} data-target={s.target} data-prefix={s.prefix} data-format={s.format}>
                {s.prefix}0
              </p>
              <p class="mt-0.5 font-mono text-[11px] leading-tight text-muted">{s.label}</p>
            </div>
          ))
        }
      </div>
      <p class="mt-3 font-mono text-[11px] text-muted">
        Cijfers uit één echte, geanonimiseerde volmachtportefeuille (125 klanten).
      </p>
    </div>
  </div>
</section>

<script>
  const LABELS = ["OP", "IN", "AVP", "AUTO", "RB", "BR"];
  const COLS = 6;
  const ROWS = 7;
  const SCAN_MS = 2600;

  const grid = document.getElementById("scan-grid")!;
  const line = document.getElementById("scan-line")!;
  const rescanBtn = document.getElementById("rescan")!;
  const counters = ["stat-polissen", "stat-leads", "stat-premie"].map(
    (id) => document.getElementById(id)!,
  );
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Vaste seed (mulberry32) zodat het patroon elke pageload gelijk is (~30% lek).
  let seed = 20260721;
  const rand = () => {
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };

  type Cell = { el: HTMLElement; leak: boolean; row: number };
  const cells: Cell[] = [];

  for (let i = 0; i < COLS * ROWS; i++) {
    const leak = rand() < 0.3;
    const el = document.createElement("div");
    el.className =
      "flex h-10 items-center justify-center rounded-md border border-line bg-surface-2 font-mono text-[11px] font-medium text-muted transition-all duration-300";
    el.textContent = LABELS[Math.floor(rand() * LABELS.length)];
    grid.appendChild(el);
    cells.push({ el, leak, row: Math.floor(i / COLS) });
  }

  const setCellState = (cell: Cell, scanned: boolean) => {
    const { el, leak } = cell;
    el.classList.toggle("bg-surface-2", !scanned);
    el.classList.toggle("text-muted", !scanned);
    if (scanned && leak) {
      el.style.background = "rgba(255,176,32,0.16)";
      el.style.borderColor = "rgba(255,176,32,0.6)";
      el.style.color = "#FFB020";
      el.style.boxShadow = "0 0 14px rgba(255,176,32,0.28)";
    } else if (scanned) {
      el.style.background = "rgba(79,209,168,0.08)";
      el.style.borderColor = "rgba(79,209,168,0.35)";
      el.style.color = "#4FD1A8";
      el.style.boxShadow = "none";
    } else {
      el.style.background = "";
      el.style.borderColor = "";
      el.style.color = "";
      el.style.boxShadow = "none";
    }
  };

  const formatValue = (el: HTMLElement, value: number) => {
    const prefix = el.dataset.prefix ?? "";
    const formatted =
      el.dataset.format === "money"
        ? Math.round(value).toLocaleString("nl-NL")
        : String(Math.round(value));
    el.textContent = prefix + formatted;
  };

  let animId = 0;

  const finishInstant = () => {
    cells.forEach((c) => setCellState(c, true));
    counters.forEach((el) => formatValue(el, Number(el.dataset.target)));
    line.style.opacity = "0";
  };

  const runScan = () => {
    cancelAnimationFrame(animId);
    if (reducedMotion) {
      finishInstant();
      return;
    }
    cells.forEach((c) => setCellState(c, false));
    counters.forEach((el) => formatValue(el, 0));

    const gridHeight = grid.offsetHeight;
    const start = performance.now();

    const tick = (now: number) => {
      const t = Math.min((now - start) / SCAN_MS, 1);
      const eased = 1 - Math.pow(1 - t, 2);
      line.style.opacity = t < 1 ? "1" : "0";
      line.style.transform = `translateY(${eased * gridHeight}px)`;

      const scanY = eased * gridHeight;
      cells.forEach((c) => {
        if (c.el.offsetTop + c.el.offsetHeight / 2 <= scanY) setCellState(c, true);
      });
      counters.forEach((el) => formatValue(el, eased * Number(el.dataset.target)));

      if (t < 1) {
        animId = requestAnimationFrame(tick);
      } else {
        cells.forEach((c) => setCellState(c, true));
        counters.forEach((el) => formatValue(el, Number(el.dataset.target)));
      }
    };
    animId = requestAnimationFrame(tick);
  };

  rescanBtn.addEventListener("click", runScan);
  runScan();
</script>
