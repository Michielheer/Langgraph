---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Klanten from "../components/Klanten.astro";
import Probleem from "../components/Probleem.astro";
import Werkwijze from "../components/Werkwijze.astro";
import LekTypes from "../components/LekTypes.astro";
import Analyse from "../components/Analyse.astro";
import Bewijs from "../components/Bewijs.astro";
import Producten from "../components/Producten.astro";
import OverOns from "../components/OverOns.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="House of Intelligence · Portefeuille-optimalisatie via cross- en upsell"
  description="Leaklight scant elke polis die je overzet op gemiste premie en zet dekkingsgaten om in concrete cross- en upsell-kansen. Portefeuille-optimalisatie voor volmachtbedrijven, gevolmachtigd agenten en verzekeraars."
>
  <Nav />
  <main>
    <Hero />
    <Klanten />
    <Probleem />
    <Werkwijze />
    <LekTypes />
    <Analyse />
    <Bewijs />
    <Producten />
    <OverOns />
    <Cta />
  </main>
  <Footer />
</Base>
